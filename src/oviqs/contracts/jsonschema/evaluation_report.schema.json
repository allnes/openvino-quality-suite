{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/allnes/openvino-quality-suite/blob/main/src/oviqs/contracts/jsonschema/evaluation_report.schema.json",
  "title": "OVIQS Evaluation Report",
  "type": "object",
  "required": ["schema_version", "run", "summary"],
  "properties": {
    "schema_version": { "type": "string" },
    "run": {
      "type": "object",
      "required": ["id", "suite", "created_at"],
      "properties": {
        "id": { "type": "string" },
        "suite": { "type": "string" },
        "model": { "type": ["string", "null"] },
        "reference": { "type": ["string", "null"] },
        "current": { "type": ["string", "null"] },
        "device": { "type": ["string", "null"] },
        "precision": { "type": ["string", "null"] },
        "created_at": { "type": "string" }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": ["overall_status"],
      "properties": {
        "overall_status": {
          "type": "string",
          "enum": ["pass", "warning", "fail", "unknown"]
        },
        "main_findings": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "metric_references": {
      "type": "object",
      "additionalProperties": true
    },
    "analysis": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "object",
          "additionalProperties": true
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "severity", "category", "status"],
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "severity": {
                "type": "string",
                "enum": ["none", "low", "medium", "high", "critical"]
              },
              "category": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["pass", "warning", "fail", "unknown"]
              },
              "evidence_paths": {
                "type": "array",
                "items": { "type": "string" }
              },
              "impact": { "type": "string" },
              "recommendation": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "section", "name", "status", "severity"],
            "properties": {
              "path": { "type": "string" },
              "section": { "type": "string" },
              "name": { "type": "string" },
              "value": { "type": ["number", "integer", "string", "boolean", "null"] },
              "status": {
                "type": "string",
                "enum": ["pass", "warning", "fail", "unknown"]
              },
              "severity": {
                "type": "string",
                "enum": ["none", "low", "medium", "high", "critical"]
              }
            },
            "additionalProperties": true
          }
        },
        "biggest_regressions": { "type": "array" },
        "biggest_improvements": { "type": "array" },
        "unknown_metrics": { "type": "array" },
        "sample_outliers": { "type": "array" },
        "trend_points": { "type": "array" }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "report_json": { "type": "string" },
        "analysis_json": { "type": "string" },
        "metrics_csv": { "type": "string" },
        "sample_metrics_jsonl": { "type": "string" },
        "index_md": { "type": "string" },
        "dashboard_html": { "type": "string" }
      },
      "additionalProperties": true
    },
    "report_metadata": {
      "type": "object",
      "properties": {
        "bundle_root": { "type": "string" }
      },
      "additionalProperties": true
    },
    "ui_hints": {
      "type": "object",
      "additionalProperties": true
    },
    "sample_metrics_summary": {
      "type": "object",
      "properties": {
        "outliers": { "type": "array" }
      },
      "additionalProperties": true
    },
    "raw_sample_metrics_uri": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": true
}
